				(text "ESP32-S3-WROOM-1x"
					(at -15.24 -20.32 0)
					(effects
						(font
							(size 1.524 1.524)
							(bold yes)
							(italic yes)
						)
					)
				)
				(text "the OSPI PSRAM and are not available for other uses."
					(at -14.605 -31.75 0)
					(effects
						(font
							(size 0.635 0.635)
						)
					)
				)
				(text "*In module variants that have embedded OSPI PSRAM, i.e.,"
					(at -13.97 -29.21 0)
					(effects
						(font
							(size 0.635 0.635)
						)
					)
				)
				(text "that embed ESP32-S3R8, pins IO35, IO36 and IO37 are connected to"
					(at -10.795 -30.48 0)
					(effects
						(font
							(size 0.635 0.635)
						)
					)
				)
				(text "ESP32-S3 has four strapping pins: GPIO0, GPIO3, GPIO45 and GPIO46."
					(at -10.414 -38.1 0)
					(effects
						(font
							(size 0.635 0.635)
						)
					)
				)
				(text "GPIO0, GPIO45 and GPIO46 are connected to the chip’s internal weak pull-up/pull-down during the chip reset."
					(at -10.16 -39.37 0)
					(effects
						(font
							(size 0.4064 0.4064)
						)
					)
				)
