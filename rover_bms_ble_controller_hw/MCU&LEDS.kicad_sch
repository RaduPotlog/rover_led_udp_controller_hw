	(text "Full-speed USB 1.1 On-The-Go (OTG) interface or USB Serial/JTAG controller.\nThe ESP32-S3 contains an USB Serial/JTAG Controller. This unit can be used to \nprogram the SoC’s flash, read program output, \nas well as attach a debugger to the running program.\nThe ESP32-S3 has an internal PHY, which is shared between \nthe USB-OTG and the USB Serial/JTAG hardware.\nEither one of these can use the internal PHY."
		(exclude_from_sim no)
		(at 386.08 171.45 0)
		(effects
			(font
				(size 1.016 1.016)
				(thickness 0.2032)
				(bold yes)
				(italic yes)
			)
			(justify right bottom)
		)
		(uuid "4ee7166e-470c-405f-84e3-6e1f1c7594ea")
	)
