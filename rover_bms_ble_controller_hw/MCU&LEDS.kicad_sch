				(text "Note:"
					(at -26.543 -36.83 0)
					(effects
						(font
							(size 0.635 0.635)
						)
					)
				)
				(text "GPIO3 is floating by default."
					(at -23.622 -40.513 0)
					(effects
						(font
							(size 0.381 0.381)
						)
					)
				)
				(text "Espressif"
					(at -17.78 35.56 0)
					(effects
						(font
							(size 2.54 2.54)
							(bold yes)
							(italic yes)
						)
